# OpenCode DevTools Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# Secrets should be managed via SOPS in nix/secrets/

# ============================================
# Service Ports
# ============================================

SEARXNG_PORT=8080
VALKEY_PORT=6379
OLLAMA_PORT=11434
LITELLM_PORT=4000
OPEN_WEBUI_PORT=3000
N8N_PORT=5678
QDRANT_PORT=6333
POSTGRES_PORT=5432

# ============================================
# Search Engine Configuration
# ============================================

# DuckDuckGo API Key (optional - improves search results)
# Get from: https://duckduckgo.com/settings
# Or leave empty for basic functionality
SEARXNG_DDG_API_KEY=

# Generate a random secret for SearXNG
SEARXNG_SECRET=changeme-generate-with-openssl-rand-hex-32

# ============================================
# NVIDIA KIMI Configuration (Free)
# ============================================

# NVIDIA KIMI API Key - Free tier available!
# Get from: https://build.nvidia.com/
NVIDIA_KIMI_API_KEY=

# ============================================
# LiteLLM Configuration
# ============================================

# Master key for LiteLLM API (change in production!)
LITELLM_MASTER_KEY=sk-devtools-12345

# Cache settings
LITELLM_DROP_CACHE=true
LITELLM_MAX_PARALLEL_REQUESTS=100

# ============================================
# Ollama Configuration
# ============================================

OLLAMA_HOST=0.0.0.0:11434
OLLAMA_MODELS=/var/lib/ollama

# ============================================
# Open WebUI Configuration
# ============================================

# Change this to a secure random string in production!
OPEN_WEBUI_SECRET_KEY=openwebui-devtools-secret-change-me

# Disable public signups (recommended)
OPEN_WEBUI_ENABLE_SIGNUP=false

# ============================================
# n8n Configuration
# ============================================

N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=devtools-change-me
N8N_HOST=0.0.0.0
N8N_PORT=5678
N8N_PROTOCOL=http

# ============================================
# Qdrant Configuration
# ============================================

QDRANT_HOST=0.0.0.0
QDRANT_GRPC_PORT=6334

# ============================================
# PostgreSQL Configuration
# ============================================

POSTGRES_DB=devtools
POSTGRES_USER=devtools
POSTGRES_PASSWORD=devtools-password-change-me

# ============================================
# General Configuration
# ============================================

TZ=Europe/Amsterdam
