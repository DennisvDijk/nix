#!/bin/bash

# ============================================================================
# SKETCHYBAR CONFIGURATION - Streamlined Setup
# ============================================================================

SCRIPT_DIR="$HOME/.config/sketchybar"

# ============================================================================
# BAR APPEARANCE
# ============================================================================

sketchybar --bar \
  position=top \
  height=32 \
  margin=10 \
  y_offset=32 \
  blur_radius=30 \
  sticky=on \
  padding_left=10 \
  padding_right=10 \
  color=0xdd1e1e2e \
  topmost=off

# ============================================================================
# DEFAULT ITEM SETTINGS
# ============================================================================

sketchybar --default \
  icon.font="SF Pro:Bold:15.0" \
  icon.color=0xffffffff \
  label.font="SF Pro:Regular:14.0" \
  label.color=0xffffffff \
  padding_left=5 \
  padding_right=5 \
  label.padding_left=4 \
  label.padding_right=10 \
  icon.padding_left=8 \
  icon.padding_right=8

# ============================================================================
# AEROSPACE WORKSPACE INTEGRATION
# ============================================================================

sketchybar --add event aerospace_workspace_change

# Create 6 workspace indicators
for sid in {1..6}; do
  sketchybar --add item space.$sid left \
    --set space.$sid \
      background.color=0x44ffffff \
      background.corner_radius=8 \
      background.height=28 \
      background.drawing=on \
      icon="$sid" \
      icon.color=0xffffffff \
      icon.padding_left=10 \
      icon.padding_right=5 \
      label.font="SF Pro:Regular:13.0" \
      label.padding_right=10 \
      click_script="aerospace workspace $sid" \
      script="$SCRIPT_DIR/workspace_update.sh" \
    --subscribe space.$sid aerospace_workspace_change
done

# ============================================================================
# CLOCK (Center)
# ============================================================================

sketchybar --add item clock center \
  --set clock \
    update_freq=10 \
    icon= \
    script='sketchybar --set clock label="$(date "+%a %d %b %H:%M")"'

# ============================================================================
# BATTERY (Right)
# ============================================================================

sketchybar --add item battery right \
  --set battery \
    update_freq=120 \
    icon.font="SF Pro:Regular:15.0" \
    script='
      PERCENTAGE=$(pmset -g batt | grep -Eo "\d+%" | cut -d% -f1)
      CHARGING=$(pmset -g batt | grep "AC Power")
      
      if [ "$PERCENTAGE" = "" ]; then exit 0; fi
      
      case ${PERCENTAGE} in
        9[0-9]|100) ICON="" ;;
        [6-8][0-9]) ICON="" ;;
        [3-5][0-9]) ICON="" ;;
        [1-2][0-9]) ICON="" ;;
        *) ICON="" ;;
      esac
      
      if [ -n "$CHARGING" ]; then ICON=""; fi
      
      sketchybar --set battery icon="$ICON" label="${PERCENTAGE}%"
    ' \
  --subscribe battery system_woke power_source_change

# ============================================================================
# VOLUME (Right)
# ============================================================================

sketchybar --add item volume right \
  --set volume \
    script='
      VOLUME=$(osascript -e "output volume of (get volume settings)")
      
      case ${VOLUME} in
        [8-9][0-9]|100) ICON="󰕾" ;;
        [4-7][0-9]) ICON="󰖀" ;;
        [1-3][0-9]) ICON="󰕿" ;;
        *) ICON="󰖁" ;;
      esac
      
      sketchybar --set volume icon="$ICON" label="${VOLUME}%"
    ' \
  --subscribe volume volume_change

# ============================================================================
# INITIALIZATION
# ============================================================================

sketchybar --update

# Update all workspaces on startup
"$SCRIPT_DIR/workspace_update.sh"