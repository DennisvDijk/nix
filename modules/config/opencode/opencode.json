{
  "$schema": "https://opencode.ai/config.json",
  "model": "lmstudio/deepseek/deepseek-r1-0528-qwen3-8b",
  "default_agent": "build",
  "provider": {
    "lmstudio": {
      "api": "openai",
      "options": {
        "baseURL": "http://localhost:1234/v1"
      },
      "models": {
        "qwen3:8b": {
          "id": "qwen3:8b"
        }
      }
    }
  },
  "plugin": [
    "opencode-wakatime",
    "opencode-helicone-session",
    "@nick-vi/opencode-type-inject",
    "@tarquinen/opencode-dcp@latest",
    "oh-my-opencode"
  ],
  "share": "manual",
  "autoupdate": "notify",
  "compaction": {
    "auto": true,
    "prune": true
  },
  "permission": {
    "read": "allow",
    "edit": "ask",
    "bash": "ask",
    "task": "allow",
    "webfetch": "allow",
    "websearch": "allow"
  },
  "tui": {
    "scroll_speed": 3,
    "scroll_acceleration": {
      "enabled": true
    },
    "diff_style": "auto"
  }
}
